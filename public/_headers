# Cache policy for static hosts that honor a _headers file (Netlify,
# Cloudflare Pages). GitHub Pages — where this project is currently
# deployed — ignores this file entirely and always serves its own fixed,
# short cache lifetime with no way to override it from the repo. Keep
# this here so the fix is a one-line hosting change away rather than a
# re-audit, if the project ever moves.
#
# /assets/* is Vite's build output: every filename is content-hashed
# (e.g. index-a1b2c3d4.js), so the file at a given URL never changes —
# safe to cache "forever".
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Everything under /images, /projects (videos), /branding, etc. comes
# from the public/ folder as-is, with stable filenames that DO change
# content without changing URL (e.g. re-exporting the same PNG). A
# shorter, revalidate-on-change policy avoids serving stale media after
# a re-export, while still meaningfully beating the host's default.
/images/*
  Cache-Control: public, max-age=86400, must-revalidate
/projects/*
  Cache-Control: public, max-age=86400, must-revalidate
/audio/*
  Cache-Control: public, max-age=86400, must-revalidate
/media/*
  Cache-Control: public, max-age=86400, must-revalidate
